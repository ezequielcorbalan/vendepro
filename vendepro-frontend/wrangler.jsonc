{
  "name": "vendepro-frontend",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-01-01",
  "compatibility_flags": ["nodejs_compat"],
  "routes": [
    { "pattern": "app.vendepro.com.ar", "custom_domain": true }
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "vendepro-db",
      "database_id": "45d18f94-807b-466f-8742-32bbc61fc7fb"
    }
  ]
}
